\draw[-{Latex}, Accent, dashed] (3.2, -1.6) -- (5.0, -1.6)
  node[right, font=\footnotesize, text=GrayDark] {Row 2 LOW + Col 2 LOW $\Rightarrow$ key (R2,C2)};
