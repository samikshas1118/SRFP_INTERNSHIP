\chapter{Mathematical Engine --- RK4 Method}
% ════════════════════════════════════════════════════════

\section{ODE Formulation of Functions}

\begin{center}
\begin{tabular}{L{2.6cm} L{4.8cm} L{4.8cm}}
\rowcolor{PrimaryDark}
\thdcell{Function $y(x)$} & \thdcell{ODE} & \thdcell{Initial Conditions} \\
\altrow $\sin(x)$ & $y'' + y = 0$ & $y(0)=0,\; y'(0)=1$ \\
$\sin^{-1}(x)$ & $\sqrt{1-x^2}\,y' - 1 = 0$ & $y(0)=0$ \\
\altrow $\tan^{-1}(x)$ & $(1+x^2)y' - 1 = 0$ & $y(0)=0$ \\
$\ln(x)$ & $x\,y' - 1 = 0$ & $y(1)=0$ \\
\altrow $e^x$ & $y' - y = 0$ & $y(0)=1$ \\
$x^w$ & $x\,y' - w\,y = 0$ & $y(1)=1$ \\
\end{tabular}
\end{center}

Derived relations:
\[
\cos x = \sin\!\left(\tfrac{\pi}{2}-x\right),\quad
\tan x = \frac{\sin x}{\cos x},\quad
\cos^{-1}(x) = \tfrac{\pi}{2} - \sin^{-1}(x),\quad
\pi = 4\tan^{-1}(1)
\]

\section{RK4 Update Equations}

\begin{formulabox}[RK4 --- First-Order ODE]
Given $\dfrac{dy}{dx} = f(x,y)$, $y(x_0)=y_0$, step size $h$:
\begin{align}
k_1 &= h\,f(x_n,\; y_n) \\
k_2 &= h\,f\!\left(x_n+\tfrac{h}{2},\; y_n+\tfrac{k_1}{2}\right) \\
k_3 &= h\,f\!\left(x_n+\tfrac{h}{2},\; y_n+\tfrac{k_2}{2}\right) \\
k_4 &= h\,f(x_n+h,\; y_n+k_3) \\[6pt]
y_{n+1} &= y_n + \frac{1}{6}(k_1 + 2k_2 + 2k_3 + k_4)
\end{align}
\end{formulabox}

\subsection{Second-Order Case: Sine Function}

$y'' + y = 0$ is split into a first-order system $\dot y = z$, $\dot z = -y$:

\begin{center}
\begin{tabular}{C{1.0cm} L{5.5cm} L{5.5cm}}
\rowcolor{PrimaryDark}
\thdcell{Step} & \thdcell{$k_i$ for $\dot y = z$} & \thdcell{$l_i$ for $\dot z = -y$} \\
\altrow 1 & $k_1 = h z_n$ & $l_1 = -h y_n$ \\
2 & $k_2 = h(z_n + l_1/2)$ & $l_2 = -h(y_n + k_1/2)$ \\
\altrow 3 & $k_3 = h(z_n + l_2/2)$ & $l_3 = -h(y_n + k_2/2)$ \\
4 & $k_4 = h(z_n + l_3)$ & $l_4 = -h(y_n + k_3)$ \\
\altrow Update & $y_{n+1} = y_n + \tfrac{1}{6}(k_1{+}2k_2{+}2k_3{+}k_4)$ & $z_{n+1} = z_n + \tfrac{1}{6}(l_1{+}2l_2{+}2l_3{+}l_4)$ \\
\end{tabular}
\end{center}

\section{Non-RK4 Functions}

\textbf{Factorial:} Simple recursion $y_n = n \cdot y_{n-1}$, $y_0 = 1$.

\textbf{Square Root:} Computed via the \textbf{Quake III} fast inverse square root, which exploits IEEE 754 bit representation:

\begin{lstlisting}[language=C, style=darkcode, caption={Fast inverse square root (Quake III method)}]
float fast_inv_sqrt(float x) {
    long  i;
    float x2 = x * 0.5f, y = x;
    i  = *(long *)&y;
    i  = 0x5f3759df - (i >> 1); // bit-level Newton seed
    y  = *(float *)&i;
    y  = y * (1.5f - (x2 * y * y)); // one Newton-Raphson step
    return y;
}
// Usage: sqrt(x) = x * fast_inv_sqrt(x)
\end{lstlisting}

