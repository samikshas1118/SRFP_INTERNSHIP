\chapter{Numerical Methods Comparative Analysis}
% ════════════════════════════════════════════════════════

\section{Methods Evaluated}

\begin{enumerate}[label=\textbf{\arabic*.}, leftmargin=*]
  \item \textbf{Forward Euler:}\; $y_{n+1} = y_n + h\cdot f(x_n, y_n)$
  \item \textbf{Backward Euler:}\; $y_{n+1} = y_n + h\cdot f(x_{n+1}, y_{n+1})$
  \item \textbf{Trapezoidal:}\; $y_{n+1} = y_n + \dfrac{h}{2}[f(x_n, y_n) + f(x_{n+1}, y_{n+1})]$
  \item \textbf{RK2 (Heun):}\; predictor--corrector with 2 function evaluations per step
  \item \textbf{RK4:}\; 4 evaluations per step, $O(h^4)$ local truncation error
\end{enumerate}

