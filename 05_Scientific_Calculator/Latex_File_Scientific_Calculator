\section{Modules Modified and Fixes Applied}

\subsection{\texttt{pars.c} --- Tokeniser Fix}

\begin{lstlisting}[language=C, style=darkcode, caption={Fixed digit-accumulation loop in \texttt{pars.c}}]
/* Accumulate ALL consecutive digit/decimal chars as one number token */
while (isdigit((unsigned char)*p) || *p == '.') {
    token_buf[tok_len++] = *p++;
}
token_buf[tok_len] = '\0';
push_operand(atof(token_buf));   /* push complete multi-digit number */
\end{lstlisting}

\subsection{\texttt{keypad.c} --- Debounce and Index Fix}
\begin{itemize}[leftmargin=*]
  \item Added 20\,ms software debounce after a LOW column is detected
  \item Corrected the $(row, col)$-to-character lookup table index offsets
\end{itemize}

\subsection{\texttt{main.c} --- Buffer and Display Fix}
\begin{itemize}[leftmargin=*]
  \item Expression buffer is now null-terminated before passing to parser
  \item \texttt{=} key handler clears LCD line 2 before printing, uses \texttt{dtostrf()} for float formatting
\end{itemize}

