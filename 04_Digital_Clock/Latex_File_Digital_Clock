\section{Design Calculations}
\label{sec:calculations}
% =========================================================
This section derives every passive-component value used in the standalone circuit. None of the values were copied from an unrelated reference design -- each follows from a short calculation given below.

\subsection{Clock Source: Crystal Load Capacitance}
\label{sec:crystalcalc}
The ATmega328P-PU needs a stable timing reference for accurate second-counting. A 16\,MHz quartz crystal is wired across the \texttt{XTAL1}/\texttt{XTAL2} pins, each leg also returned to ground through a capacitor (Figure~\ref{fig:crystal}).

\begin{figure}[H]
\centering
\begin{circuitikz}[scale=1.05, color=pcbDark, american]
\draw (0,0) node[anchor=east]{XTAL1} to[piezoelectric, l=$Y_1$ 16\,MHz, *-*] (4.8,0) node[anchor=west]{XTAL2};
\draw (1.3,0) to[C, l_=$C_1$ 22\,pF, color=copper] (1.3,-2) node[ground]{};
\draw (3.5,0) to[C, l_=$C_2$ 22\,pF, color=copper] (3.5,-2) node[ground]{};
\end{circuitikz}
\caption{Crystal oscillator network: a 16\,MHz crystal with two 22\,pF load capacitors returned to ground.}
\label{fig:crystal}
\end{figure}

\begin{calcbox}[Load Capacitance Calculation]
The crystal's effective load capacitance is:
\[
C_L = \frac{C_1 C_2}{C_1+C_2} + C_{\text{stray}}
\]
With $C_1=C_2=22\,\text{pF}$:
\[
\frac{C_1 C_2}{C_1+C_2} = \frac{22\times22}{22+22} = 11\,\text{pF}
\]
Adding a typical board/breadboard stray capacitance of $C_{\text{stray}} \approx 4$--$5\,\text{pF}$ gives:
\[
C_L \approx 15\text{--}16\,\text{pF}
\]
This sits inside the load-capacitance window most 16\,MHz AVR-grade crystals are specified for, which is why \textbf{22\,pF} is the standard, datasheet-recommended capacitor value for this oscillator circuit -- and why it was chosen here rather than a smaller or larger value.
\end{calcbox}

\subsection{Decoupling Capacitor Network}
\label{sec:decoupling}
Two 100\,nF ceramic capacitors bypass the digital supply (\texttt{VCC}) and the analog supply (\texttt{AVCC}) directly to ground, placed as close to the chip's pins as practical (Figure~\ref{fig:decoupling}).

\begin{figure}[H]
\centering
\begin{circuitikz}[scale=1.05, color=pcbDark, american]
\draw (0,2) node[anchor=south]{VCC} to[short] (0,1.5) to[C, l_=$C_3$ 100\,nF, color=copper] (0,0) node[ground]{};
\draw (2.6,2) node[anchor=south]{AVCC} to[short] (2.6,1.5) to[C, l_=$C_4$ 100\,nF, color=copper] (2.6,0) node[ground]{};
\end{circuitikz}
\caption{Decoupling network on VCC and AVCC.}
\label{fig:decoupling}
\end{figure}

\begin{designnote}[Why this matters]
Every time the multiplexer routine switches a digit or the firmware toggles a segment, the chip's internal switching draws a brief current spike. Without local decoupling, that spike shows up as a voltage dip on the supply rail -- large enough, in some cases, to dip below the chip's minimum operating voltage and cause a spurious reset. The 100\,nF capacitors act as tiny local reservoirs that supply this instantaneous current, keeping the rail flat.
\end{designnote}

\subsection{Reset Pull-Up Network}
\label{sec:reset}
The \texttt{RESET} pin is active-low: pulling it to ground resets the chip. Left unconnected, it is a high-impedance node that can be pulled low by noise alone. A 10\,k$\Omega$ resistor to \texttt{5V} (Figure~\ref{fig:reset}) holds it firmly HIGH during normal operation.

\begin{figure}[H]
\centering
\begin{circuitikz}[scale=1.05, color=pcbDark, american]
\draw (0,2.2) node[anchor=south]{5\,V} to[short] (0,1.8) to[R, l_=$R_1$ 10\,k$\Omega$, color=copper] (0,0) to[short] (1.6,0) node[anchor=west]{RESET};
\end{circuitikz}
\caption{External RESET pull-up resistor.}
\label{fig:reset}
\end{figure}

\subsection{Segment Current-Limiting Resistor}
\label{sec:resistorcalc}
Each seven-segment LED needs a series resistor so the current through it stays in a safe, consistently bright range. Figure~\ref{fig:segment} shows the arrangement for one segment line; the same resistor value is reused for all seven segment lines (a--g) since they share identical electrical characteristics.

\begin{figure}[H]
\centering
\begin{circuitikz}[scale=1.05, color=pcbDark, american]
\draw (0,0) node[anchor=east]{GPIO pin} to[R, l_=330\,$\Omega$, color=copper] (2.3,0) to[leD, l_=Segment] (4.4,0) node[anchor=west]{Common};
\end{circuitikz}
\caption{Current-limiting resistor in series with one display segment.}
\label{fig:segment}
\end{figure}

\begin{calcbox}[Ohm's Law Resistor Sizing]
\[
R = \frac{V_{\text{supply}} - V_f}{I_{\text{segment}}}
\]
With a 5\,V supply, a typical red-LED segment forward drop $V_f \approx 2\,\text{V}$, and a target segment current of $I=10\,\text{mA}$:
\[
R = \frac{5 - 2}{0.01} = 300\,\Omega
\]
The closest standard (E12 series) resistor value \emph{above} the calculated minimum is:
\[
\boxed{R = 330\,\Omega}
\]
\end{calcbox}

\begin{designnote}[Power Budget Check]
With 7 segments lit at \textasciitilde 10\,mA each, a fully-lit digit (e.g. "8") momentarily draws up to $7 \times 10\,\text{mA} = 70\,\text{mA}$ through its active digit line. This is comfortably below the ATmega328P's absolute device-level current budget, but it is \emph{above} the recommended continuous 20\,mA-per-pin guideline for a single AVR I/O pin. Because the display is multiplexed -- only one digit is ever fully lit at an instant, each for a few milliseconds -- the \emph{average} current per pin over a full refresh cycle is far lower than this peak. As good practice for any future revision, routing the digit-select (common) lines through a small NPN/PNP transistor or low-$R_{DS}$ MOSFET per digit -- rather than driving them straight from the microcontroller -- keeps every AVR pin safely inside its rated current and is the standard approach in commercial multiplexed-display products.
\end{designnote}

