.include "m328pdef.inc"

.org 0x0000
rjmp MAIN

MAIN:

ldi r16,0b00111100
out DDRD,r16

LOOP:

ldi r17,0

NEXT:

mov r18,r17
lsl r18
lsl r18

out PORTD,r18

sbi PORTD,5

rcall DELAY

inc r17
cpi r17,8
brne NEXT

rjmp LOOP

DELAY:

ldi r20,100

L1:
ldi r21,255

L2:
ldi r22,255

L3:
dec r22
brne L3

dec r21
brne L2

dec r20
brne L1

ret
