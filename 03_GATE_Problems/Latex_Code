\section{Circuit Analysis and Simplification}

\subsection{Step-by-Step Derivation}

\begin{tcolorbox}[stepbox]
\textbf{Step 1 \textemdash{} First-Stage NAND Gate Outputs}\\[4pt]
The outputs of the two input-stage NAND gates are expressed as:
\[
  X_1 = \overline{\bar{A}\,B} \qquad X_2 = \overline{B\,\bar{C}}
\]

\medskip
\textbf{Step 2 \textemdash{} Application of DeMorgan's Theorem}\\[4pt]
Applying DeMorgan's theorem to each expression:
\[
  X_1 = A + \bar{B} \qquad X_2 = \bar{B} + C
\]

\medskip
\textbf{Step 3 \textemdash{} OR Gate Combination}\\[4pt]
The OR gate combines $X_1$ and $X_2$:
\[
  X_3 = X_1 + X_2 = A + \bar{B} + C
\]

\medskip
\textbf{Step 4 \textemdash{} Self-Input NAND (NOT) Gates}\\[4pt]
Two additional NAND gates with identical inputs function as inverters:
\[
  X_4 = \overline{A \cdot A} = \bar{A} \qquad X_5 = \overline{C \cdot C} = \bar{C}
\]

\medskip
\textbf{Step 5 \textemdash{} Final Output Expression}\\[4pt]
\begin{align*}
  Y &= X_3 + X_4 + X_5 \\
    &= (A + \bar{B} + C) + \bar{A} + \bar{C} \\
    &= (A + \bar{A}) + \bar{B} + (C + \bar{C}) \\
    &= 1 + \bar{B} + 1
\end{align*}
\end{tcolorbox}

\vspace{8pt}
\begin{tcolorbox}[resultbox]
\[
  \boldsymbol{Y = 1}
\]
The output is \textbf{always logic HIGH}, irrespective of the values of inputs
$A$, $B$, or $C$. This establishes that the original circuit is logically
redundant and may be replaced entirely by a direct connection to the supply
voltage (V\textsubscript{CC}).
\end{tcolorbox}

